# Voice VARK — LLM for mapping speech to VARK option IDs
# Option A: OpenRouter (get a key at https://openrouter.ai/keys)
VITE_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Voice backend (TTS + STT) for <2s latency — server-side only, not VITE_ prefixed
# Get a key at https://platform.openai.com/api-keys
# Run: OPENAI_API_KEY=sk-... npm run server (and npm run dev in another terminal)
OPENAI_API_KEY=sk-your-openai-key-here

# Option B: ChatJimmy proxy (Taalas HC1 / Llama 3.1 8B). If set, overrides OpenRouter; no API key needed.
# See docs/chatjimmy-proxy.md
# VITE_LLM_BASE_URL=https://private-llm-proxy.redacted.invalid/v1

# Optional: Kokoro TTS voice. Default in app: bf_lily (British female, clear/warm).
# British: bf_lily, bf_emma, bf_isabella, bf_alice. American: af_bella, af_heart, af_nicole, etc.
# Kokoro has no Australian voices; use a cloud TTS if you need Australian.
# VITE_TTS_VOICE=bf_lily

# Optional: load TTS/STT models from a URL instead of Hugging Face.
# - Local (no OpenAI): run npm run download-voice-models then npm run serve-models; set to http://localhost:8080
# - Remote cache: any https:// URL that mirrors HF model files. See docs/local-voice-models.md and docs/tts-model-proxy.md.
# VITE_TTS_MODEL_PROXY_URL=http://localhost:8080
